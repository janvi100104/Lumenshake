# Application
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumenshake
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumenshake
DB_USER=postgres
DB_PASSWORD=postgres

# Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# Primary RPC used by backend routes/services
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# Compatibility key used by some scripts/docker setups
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=YOUR_CONTRACT_ID
NETWORK=testnet

# Frontend and API routing
FRONTEND_URL=http://localhost:3000
ANCHOR_URL=http://localhost:4000
BASE_URL=http://localhost:4000
API_URL=http://localhost:4000/api

# SEP-10 Authentication
HOME_DOMAIN=localhost:4000
WEB_AUTH_DOMAIN=LumenShake Payroll
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=24h

# MoneyGram
MONEYGRAM_API_KEY=your-moneygram-api-key
MONEYGRAM_API_SECRET=your-moneygram-api-secret
MONEYGRAM_API_URL=https://api.moneygram.com/api/v1
PIN_ENCRYPTION_KEY=replace-with-32-character-key
